# Normalize text for stable hashes across platforms.
* text=auto eol=lf

# Source and metadata are LF text.
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Archives and binary assets are never line-ending normalized.
*.zip binary
*.tgz binary
*.tar binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
